#!/usr/bin/env bash
#
# Pre-commit hook: block commits that contain secrets or env variables.
#
# Install:  cp scripts/pre-commit .git/hooks/pre-commit
# Bypass:   git commit --no-verify
#

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

# 1. Block .env files from being committed
env_files=$(git diff --cached --name-only | grep -E '(^|/)\.env($|\..*)' | grep -v '\.env\.example$' || true)
if [[ -n "$env_files" ]]; then
    echo -e "${RED}BLOCKED:${NC} .env file(s) staged for commit:"
    echo "$env_files"
    echo "Remove with: git reset HEAD <file>"
    exit 1
fi

# 2. Scan staged diffs for secret patterns
patterns=(
    # Zep / generic API keys
    'z_[A-Za-z0-9_-]{20,}'
    # OpenAI
    'sk-[A-Za-z0-9]{20,}'
    # Anthropic
    'sk-ant-[A-Za-z0-9_-]{20,}'
    # AWS access key IDs
    'AKIA[0-9A-Z]{16}'
    # Generic secret assignments (key = "...", token = "...", etc.)
    '(api_key|api_secret|secret_key|access_token|auth_token|password|credential)['"'"'""]?\s*[:=]\s*['"'"'""][A-Za-z0-9_/+=\-]{8,}['"'"'""]'
    # Bearer tokens
    'Bearer\s+[A-Za-z0-9_.=-]{20,}'
    # Private keys
    '-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----'
    # GitHub tokens
    'gh[pousr]_[A-Za-z0-9_]{36,}'
    # Generic long hex secrets (e.g. 40-char hex after "key" or "token")
    '(KEY|TOKEN|SECRET|PASSWORD)\s*=\s*['"'"'""]?[0-9a-fA-F]{32,}['"'"'""]?'
)

combined_pattern=$(IFS='|'; echo "${patterns[*]}")

# Only scan added/modified lines (lines starting with +, excluding the +++ header)
matches=$(git diff --cached -U0 --diff-filter=ACMR | grep -E '^\+[^+]' | grep -iE "$combined_pattern" || true)

if [[ -n "$matches" ]]; then
    echo -e "${RED}BLOCKED:${NC} Possible secrets detected in staged changes:"
    echo ""
    echo "$matches" | head -20
    echo ""
    echo -e "${YELLOW}If these are false positives, commit with:${NC}"
    echo "  git commit --no-verify"
    exit 1
fi
